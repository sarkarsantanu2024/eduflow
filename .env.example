# ──────────────────────────────────────────────────────────────
# EduFlow — Environment Variables
# Local dev: copy to `.env.local`.  Production: set these in Vercel.
# ──────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────

# Neon Postgres — "Pooled connection" string (host contains -pooler).
DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Auth.js session secret. Generate with: npx auth secret
# Use a DIFFERENT value in production than in local dev.
AUTH_SECRET=replace-with-a-long-random-string

# Public base URL of the app.
#   local dev   → http://localhost:3000
#   production  → https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=EduFlow

# ── SEED ONLY (used once by `npm run db:seed`, not at runtime) ─
SUPERADMIN_EMAIL=sarkarsantanu69@gmail.com
SUPERADMIN_PASSWORD=set-a-strong-password

# ── OPTIONAL (add only when the feature is enabled) ───────────
# File uploads (student photos, logos, certificate templates):
# Vercel → Storage → create a Blob store → copy the token.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx
